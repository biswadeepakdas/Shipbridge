# ============================================================
# ShipBridge — Environment Variables
# ============================================================
# Copy this file to apps/api/.env and fill in your values.
# Variables marked REQUIRED must be set before starting the API.
# Variables marked OPTIONAL degrade gracefully if left blank.
# ============================================================


# ------------------------------------------------------------
# DATABASE  [REQUIRED]
# ------------------------------------------------------------
# Async PostgreSQL connection string (asyncpg driver).
# The default points to the local Docker Compose instance.
# For production, use a managed Postgres service (e.g. Supabase,
# Neon, RDS) and enable SSL: ?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shipbridge


# ------------------------------------------------------------
# REDIS  [REQUIRED]
# ------------------------------------------------------------
# Redis connection string. Used for Redis Streams (event bus)
# and caching. The default points to the local Docker instance.
REDIS_URL=redis://localhost:6379/0


# ------------------------------------------------------------
# AUTHENTICATION  [REQUIRED]
# ------------------------------------------------------------
# Secret key used to sign and verify JWT tokens.
# Generate a strong value with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256


# ------------------------------------------------------------
# OPENAI  [REQUIRED]
# ------------------------------------------------------------
# Used for text embeddings (text-embedding-3-small) in the
# OS layer context service, and for LLM routing decisions.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...


# ------------------------------------------------------------
# ANTHROPIC  [REQUIRED for HITL Gate]
# ------------------------------------------------------------
# Used by the HITL rule-generation worker (Claude Sonnet).
# Without this key, the rule_gen worker will skip LLM generation
# and log a warning — the rest of the API continues to work.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...


# ------------------------------------------------------------
# SUPABASE  [OPTIONAL]
# ------------------------------------------------------------
# Supabase is used as an alternative auth and storage backend.
# If running fully locally with plain Postgres, leave these blank.
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=


# ------------------------------------------------------------
# TEMPORAL  [OPTIONAL — set USE_TEMPORAL=false for local dev]
# ------------------------------------------------------------
# Temporal provides durable workflow orchestration for staged
# rollouts (Sandbox → Canary 5% → Canary 25% → Production).
# Set USE_TEMPORAL=false to run rollout logic in-process without
# durability — safe for local development and testing.
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=shipbridge
USE_TEMPORAL=false


# ------------------------------------------------------------
# APP SETTINGS
# ------------------------------------------------------------
# ENVIRONMENT: development | staging | production
# Controls log verbosity, Sentry sampling, and feature flags.
ENVIRONMENT=development

# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# Public base URL of this API — used in webhook callback URLs
# and CORS configuration. Update for production deployments.
API_BASE_URL=http://localhost:8000

# Public base URL of the frontend — used in CORS allow-origins.
# Update to your deployed frontend domain in production.
WEB_BASE_URL=http://localhost:3000


# ------------------------------------------------------------
# GITHUB APP  [OPTIONAL — required for GitHub connector]
# ------------------------------------------------------------
# Create a GitHub App at: https://github.com/settings/apps/new
# The private key should be the contents of the downloaded .pem file.
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
# Path to the GitHub App private key PEM file (relative to apps/api/)
# GITHUB_PRIVATE_KEY_PATH=github-app.pem


# ------------------------------------------------------------
# SALESFORCE  [OPTIONAL — required for Salesforce connector]
# ------------------------------------------------------------
# Standard Salesforce credentials. Generate a security token from:
# Salesforce → Settings → My Personal Information → Reset Security Token
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com


# ------------------------------------------------------------
# NOTION  [OPTIONAL — required for Notion connector]
# ------------------------------------------------------------
# Create an integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=


# ------------------------------------------------------------
# STRIPE  [OPTIONAL — required for usage billing]
# ------------------------------------------------------------
# Used by the stripe_metering service to report token usage.
# Without this key, the Costs page uses local aggregated data only.
# Get your key at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=


# ------------------------------------------------------------
# OBSERVABILITY  [OPTIONAL]
# ------------------------------------------------------------

# Sentry — error tracking and performance monitoring.
# Get your DSN at: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=

# OpenTelemetry — export traces to any OTLP-compatible collector
# (Jaeger, Grafana Tempo, Honeycomb, Datadog, etc.)
# Example: http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# BetterStack — uptime heartbeat ping URL.
# Get your heartbeat URL at: https://betterstack.com/uptime
BETTERSTACK_HEARTBEAT_URL=


# ------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------
# Set to true in staging to inject controlled latency/error faults
# for chaos testing the rollback pipeline.
ENABLE_CHAOS_TESTING=false
